# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# captures d'écran générées
/screenshots

# fichiers uploadés (CV des candidats, etc.)
/uploads

# typescript
*.tsbuildinfo
next-env.d.ts

# clone temporaire segnoogo (transposition)
gestrh-src/

# Données réelles (PII) — ne pas committer
SIRH_UNIVERSITE_ST_CHRISTOPHER_.xlsx

# Seed généré depuis les données réelles (PII)
prisma/seed-data.json
prisma/seed.sql

# Bulletins de paie / PDF (PII)
*.pdf

# Modèles d'attestation fournis par l'organisation (servent de référence)
TEMPLATE*.docx
TEMPLATES*.docx
*ATTESTATION*.docx
