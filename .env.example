# Connexion PostgreSQL.
# Ces valeurs correspondent à la base lancée par `docker compose up`.
# Pour une base PostgreSQL installée autrement, adapter l'URL :
# postgresql://UTILISATEUR:MOTDEPASSE@HOTE:PORT/BASE?schema=public
DATABASE_URL="postgresql://sirh:sirh_dev_pwd@localhost:5432/sirh_st_christopher?schema=public"

# Clé de signature des sessions (JWT). Générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="changez-moi-en-prod-avec-une-cle-aleatoire-32-octets"
