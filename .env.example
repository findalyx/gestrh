# ============================================================
#  Variables d'environnement — SIRH St Christopher
#  Copier ce fichier en `.env`.
# ============================================================

# ----------------------------------------------------------
#  Connexion PostgreSQL
# ----------------------------------------------------------
# En local : base PostgreSQL lancée par `docker compose up`.
# En prod Supabase : copier la chaîne « Transaction pooler » depuis
# Supabase → Connect, en remplaçant [YOUR-PASSWORD] par le mot de passe
# de la base, et en ajoutant `?pgbouncer=true&connection_limit=1`.
DATABASE_URL="postgresql://sirh:sirh_dev_pwd@localhost:5432/sirh_st_christopher?schema=public"

# ----------------------------------------------------------
#  Sécurité — clé de signature des sessions (JWT)
# ----------------------------------------------------------
# Générer avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET="changez-moi-en-prod-avec-une-cle-aleatoire-32-octets"

# ----------------------------------------------------------
#  Supabase Storage — uploads de fichiers (contrats, logo, CV, pièces jointes)
# ----------------------------------------------------------
# Supabase → Settings → API
#   - SUPABASE_URL              = "Project URL" (ex: https://xxxxx.supabase.co)
#   - SUPABASE_SERVICE_ROLE_KEY = "service_role" key (gardée SECRÈTE, jamais côté client)
#
# Nécessite aussi qu'un bucket "gestrh-files" existe dans Supabase Storage
# (privé, RLS activé). Création :
#   Supabase Dashboard → Storage → New bucket → Name: gestrh-files → Private
SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
