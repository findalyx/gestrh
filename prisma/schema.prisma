// ============================================================
//  SIRH Université St Christopher — Schéma de base de données
//  Base : PostgreSQL (multi-utilisateurs, accès concurrents)
//  ORM  : Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  ÉNUMÉRATIONS
// ============================================================

/// Profils utilisateurs (§4 des spécifications)
enum Role {
  DIRECTION // Direction Générale / DG — accès complet, vue stratégique
  RECTEUR   // Recteur — autorité finale (alternative au DG sur les congés)
  DOYEN     // Doyen Académique ou Exécutif — validation intermédiaire des congés
  DRH       // DRH / Responsable RH — accès complet RH
  MANAGER   // Responsable / Chef de Service — accès limité à son équipe
  AGENT     // Agent PER ou PATS — accès à son propre dossier
}

/// Catégorie de personnel (§3)
enum StaffCategory {
  PER         // Personnel Enseignant et Recherche
  PATS        // Personnel Administratif, Technique et de Service
  PRESTATAIRE // Prestataire de services — permanent, contrat de prestation
}

/// Sous-catégorie de personnel
enum StaffSubCategory {
  PER_ENSEIGNEMENT
  PER_RECHERCHE
  PATS_ADMINISTRATIF
  PATS_TECHNIQUE
  PRESTATAIRE_SERVICE
}

enum Gender {
  HOMME
  FEMME
}

enum AgentStatus {
  ACTIF
  SUSPENDU
  RETRAITE
  INACTIF
}

enum ContractType {
  CDI
  CDD
  VACATAIRE
  STAGE
  PRESTATION // Contrat de prestation de services (prestataires permanents)
}

enum ContractStatus {
  ACTIF
  EXPIRE
  RENOUVELE
  RESILIE
  EN_ATTENTE_SIGNATURE
  ROMPU
}

// --- Workflow contrats (transposé depuis segnoogo/gestRH) ---

enum AmendmentType {
  SALAIRE
  GRADE
  FONCTION
  HORAIRES
  MUTATION
  AUTRE
}

enum RenewalDecision {
  EN_COURS
  RENOUVELE
  CONVERTI_CDI
  NON_RENOUVELE
}

enum ResignationStatus {
  SOUMISE
  ACCUSEE
  ACCEPTEE
  REJETEE
  EN_PREAVIS
  EFFECTIVE
  ANNULEE
}

enum ContractNotificationKind {
  RENOUVELLEMENT
  NON_RENOUVELLEMENT
  FIN_PERIODE_ESSAI
  RUPTURE_ANTICIPEE
  CONFIRMATION_PERIODE_ESSAI
}

enum LeaveType {
  ANNUEL
  MALADIE
  MATERNITE
  PATERNITE
  EXCEPTIONNEL
  SANS_SOLDE
}

/// Workflow de validation des congés (Université St Christopher) :
/// Employé -> Chef de Service -> Doyen -> DG/Recteur -> Autorisé.
/// (Personnel du service « Direction Générale » : Employé -> DG directement.)
enum LeaveStatus {
  BROUILLON
  EN_ATTENTE_CHEF
  EN_ATTENTE_DOYEN
  EN_ATTENTE_DG
  AUTORISE
  REFUSE
  ANNULE
}

/// Niveau de validation dans la chaîne des congés.
enum LeaveApprovalLevel {
  CHEF
  DOYEN
  DG_RECTEUR
}

/// Sens de la décision prise à un niveau de validation.
enum LeaveDecision {
  FAVORABLE
  DEFAVORABLE
}

enum EvaluationStatus {
  PLANIFIEE
  EN_COURS
  TERMINEE
  EN_RETARD
}

enum TrainingStatus {
  PLANIFIEE
  OUVERTE
  EN_COURS
  TERMINEE
  ANNULEE
}

enum EnrollmentStatus {
  INSCRIT
  CONFIRME
  REALISE
  ABANDONNE
}

enum JobStatus {
  OUVERT
  EN_COURS
  POURVU
  FERME
}

/// Étapes du pipeline de recrutement (§5.5)
enum ApplicationStage {
  CANDIDATURE
  PRESELECTION
  ENTRETIEN
  FINALISTE
  RECRUTE
  REJETE
}

enum PayrollStatus {
  BROUILLON
  VALIDE
  PAYE
}

/// Statut d'une prestation mensuelle (prestataires de services).
enum PrestationStatus {
  EN_ATTENTE // document mensuel pas encore reçu / signé
  SIGNE      // document signé reçu, base de paiement établie
  PAYE       // paiement effectué
}

enum DocumentType {
  CONTRAT
  CONTRAT_SIGNE
  AVENANT
  AVENANT_SIGNE
  DEMISSION
  NOTIFICATION_CONTRAT
  DIPLOME
  CERTIFICATION
  BULLETIN_PAIE
  JUSTIFICATIF
  CNI
  CASIER_JUDICIAIRE
  RIB
  PHOTO
  CERTIFICAT_MEDICAL
  CV
  AUTRE
}

enum NotificationType {
  ALERTE
  INFO
  RAPPEL
  VALIDATION
}

// ============================================================
//  AUTHENTIFICATION & SÉCURITÉ
// ============================================================

/// Compte de connexion. Lié optionnellement à une fiche Agent.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(AGENT)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent            Agent?            @relation(fields: [agentId], references: [id])
  agentId          String?           @unique
  notifications    Notification[]
  announcements    Announcement[]
  auditLogs        AuditLog[]
  applicationNotes ApplicationNote[]

  // Workflow contrats (transposé depuis segnoogo/gestRH)
  uploadedDocuments     Document[]             @relation("DocumentUploader")
  renewalDecisions      ContractRenewal[]      @relation("RenewalDecider")
  resignationDecisions  Resignation[]          @relation("ResignationDecider")
  contractNotifications ContractNotification[] @relation("NotificationSender")
  leaveApprovals        LeaveApproval[]        @relation("LeaveApprovalDecider")
}

/// Paramètres applicatifs (clé / valeur). Pour stocker des compteurs ou
/// états globaux : dernier calcul de solde, version active, etc.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Identité de l'organisation (singleton). Sert pour l'en-tête de l'app,
/// le logo, les bulletins de paie, les exports, etc.
model Organization {
  id           String   @id @default(cuid())
  name         String   // ex: "Université St Christopher"
  shortName    String?  // ex: "USC" (pour les pastilles)
  tagline      String?  // ex: "SIRH · Université"
  address      String?
  city         String?
  country      String   @default("Sénégal")
  ninea        String?  // n° fiscal
  rccm         String?  // registre du commerce
  phone        String?
  email        String?
  website      String?
  // Informations légales (figurent sur les contrats générés)
  capital       BigInt? // capital social en FCFA
  bp            String? // boîte postale
  legalRepName  String? // nom du représentant légal (signataire des contrats)
  legalRepTitle String? // titre / fonction, ex: "Directeur Général", "Recteur"
  // Logo uploadé ; chemin = ./uploads/branding/{logoFilename}
  logoFilename String?
  logoMimeType String?
  updatedAt    DateTime @updatedAt
}

/// Journal d'audit — traçabilité de toutes les actions RH (§5.9, §8.3)
model AuditLog {
  id        String   @id @default(cuid())
  action    String   // ex: "CREATE_AGENT", "APPROVE_LEAVE"
  entity    String   // ex: "Agent", "LeaveRequest"
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([entity, entityId])
}

// ============================================================
//  ORGANISATION
// ============================================================

/// Service / département de l'université
model Service {
  id          String  @id @default(cuid())
  name        String  @unique
  code        String  @unique
  description String?

  agents     Agent[] @relation("ServiceMembers")
  manager    Agent?  @relation("ServiceManager", fields: [managerId], references: [id])
  managerId  String? @unique

  jobPostings JobPosting[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// ============================================================
//  MODULE 5.2 — GESTION DU PERSONNEL
// ============================================================

/// Fiche individuelle d'un agent (PER ou PATS)
model Agent {
  id             String           @id @default(cuid())
  matricule      String           @unique
  firstName      String
  lastName       String
  email          String           @unique
  phone          String?
  birthDate      DateTime?
  birthPlace     String?
  nationality    String?
  maritalStatus  String?
  gender         Gender
  address        String?
  category       StaffCategory
  subCategory    StaffSubCategory
  jobTitle       String
  status         AgentStatus      @default(ACTIF)
  hireDate       DateTime
  photoUrl       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  service   Service @relation("ServiceMembers", fields: [serviceId], references: [id])
  serviceId String

  managedService Service? @relation("ServiceManager")
  user           User?

  contracts          Contract[]
  leaveRequests      LeaveRequest[]      @relation("LeaveRequester")
  leaveApprovals     LeaveRequest[]      @relation("LeaveApprover")
  leaveBalances      LeaveBalance[]
  evaluationsReceived Evaluation[]       @relation("Evaluee")
  evaluationsGiven   Evaluation[]        @relation("Evaluator")
  enrollments        TrainingEnrollment[]
  payrollRecords     PayrollRecord[]
  prestationInvoices PrestationInvoice[]
  documents          Document[]
  careerEntries      CareerEntry[]

  @@index([category])
  @@index([serviceId])
}

/// Historique de carrière et postes occupés (§5.2)
model CareerEntry {
  id        String   @id @default(cuid())
  jobTitle  String
  startDate DateTime
  endDate   DateTime?
  notes     String?

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String
}

/// Contrat de travail
model Contract {
  id          String         @id @default(cuid())
  reference   String         @unique
  type        ContractType
  status      ContractStatus @default(ACTIF)
  startDate   DateTime
  endDate     DateTime?
  grade       String?        // échelon / grille salariale
  baseSalary  Int            // salaire de base en FCFA
  // PDF du contrat (auto-généré ou scan signé) — chemin = ./uploads/contracts/{id}/{pdfFilename}
  pdfFilename  String?
  pdfMimeType  String?
  pdfSize      Int?
  // true = PDF auto-généré par le système (peut être ré-écrasé en bulk)
  // false = scan signé téléversé manuellement (à ne pas écraser)
  pdfGenerated Boolean        @default(false)

  // --- Workflow contrats (transposé depuis segnoogo/gestRH) ---
  probationEndDate DateTime? // fin de période d'essai
  noticePeriodDays Int? // durée du préavis en jours
  workingHours     Int? // heures hebdomadaires
  clauses          String? // clauses spécifiques libres
  // Contrat signé téléversé dans le cadre du workflow (Supabase :
  // contracts/{id}/signed/{filename}). Distinct du pdf* auto-généré ci-dessus.
  signedFileName   String?
  signedMimeType   String?
  signedSize       Int?
  signedAt         DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  documents     Document[]
  amendments    ContractAmendment[]
  renewal       ContractRenewal?
  resignation   Resignation?
  notifications ContractNotification[]

  @@index([status])
  @@index([endDate])
}

// ============================================================
//  WORKFLOW CONTRATS — avenants, renouvellement, démission,
//  notifications (transposé depuis segnoogo/gestRH, stockage Supabase)
// ============================================================

/// Avenant à un contrat (modification de salaire, fonction, grade, etc.)
/// Fichier signé sur Supabase : amendments/{id}/signed/{filename}
model ContractAmendment {
  id             String        @id @default(cuid())
  reference      String        @unique
  type           AmendmentType
  effectiveDate  DateTime
  description    String
  oldValue       String?
  newValue       String?
  signedFileName String?
  signedMimeType String?
  signedSize     Int?
  signedAt       DateTime?
  createdAt      DateTime      @default(now())

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String

  @@index([contractId])
}

/// Décision DRH sur le renouvellement d'un CDD à échéance
model ContractRenewal {
  id            String          @id @default(cuid())
  decision      RenewalDecision @default(EN_COURS)
  decidedAt     DateTime?
  reason        String?
  newEndDate    DateTime? // si renouvelé : nouvelle fin
  newContractId String? // si converti CDI : id du nouveau contrat
  notifiedAt    DateTime? // notification envoyée à l'agent
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  String   @unique
  decidedBy   User?    @relation("RenewalDecider", fields: [decidedById], references: [id])
  decidedById String?

  @@index([decision])
}

/// Démission soumise par un agent (CDI ou CDD)
/// Lettre signée sur Supabase : resignations/{id}/signed/{filename}
model Resignation {
  id              String            @id @default(cuid())
  submittedAt     DateTime          @default(now())
  effectiveDate   DateTime // date de départ souhaitée
  noticeStartDate DateTime?
  status          ResignationStatus @default(SOUMISE)
  reason          String?
  hrComment       String?
  decidedAt       DateTime?
  signedFileName  String?
  signedMimeType  String?
  signedSize      Int?

  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId  String   @unique
  decidedBy   User?    @relation("ResignationDecider", fields: [decidedById], references: [id])
  decidedById String?

  @@index([status])
}

/// Notification formelle envoyée par la Direction/DRH à un agent
/// concernant son contrat (renouvellement, non-renouvellement, fin essai…)
/// Lettre générée sur Supabase : contract-notifications/{id}/{filename}
model ContractNotification {
  id             String                   @id @default(cuid())
  kind           ContractNotificationKind
  subject        String
  body           String
  sentAt         DateTime                 @default(now())
  acknowledgedAt DateTime?
  fileName       String?
  mimeType       String?
  size           Int?

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String
  sentBy     User?    @relation("NotificationSender", fields: [sentById], references: [id])
  sentById   String?

  @@index([contractId])
  @@index([kind])
}

// ============================================================
//  MODULE 5.3 — PAIE & AVANTAGES SOCIAUX
// ============================================================

/// Bulletin de paie mensuel d'un agent
model PayrollRecord {
  id          String        @id @default(cuid())
  period      String        // ex: "2025-05"
  baseSalary  Int           // FCFA
  bonuses     Int           @default(0) // primes & indemnités
  allowances  Int           @default(0) // allocations
  deductions  Int           @default(0) // cotisations CSS / IPRES / IPM
  netSalary   Int
  status      PayrollStatus @default(BROUILLON)
  pdfUrl      String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  @@unique([agentId, period])
  @@index([period])
}

/// Prestation mensuelle d'un prestataire de services.
/// Chaque mois, le prestataire signe un document (bon de commande / facture /
/// attestation de service fait) qui sert de base au paiement et tient lieu de
/// bulletin. Le PDF signé est stocké sur Supabase Storage.
model PrestationInvoice {
  id           String           @id @default(cuid())
  period       String           // "2026-05"
  amount       Int              // montant de la prestation du mois, en FCFA
  label        String?          // ex: "Vacations mars", "Enseignement + jury"
  status       PrestationStatus @default(EN_ATTENTE)
  // Document mensuel signé — chemin Supabase = prestations/{agentId}/{filename}
  documentName String?
  documentPath String?
  documentSize Int?
  paidAt       DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  @@unique([agentId, period])
  @@index([period])
}

// ============================================================
//  MODULE 5.4 — CONGÉS & ABSENCES
// ============================================================

/// Demande de congé soumise à validation hiérarchique
model LeaveRequest {
  id        String      @id @default(cuid())
  type      LeaveType
  status    LeaveStatus @default(BROUILLON)
  startDate DateTime
  endDate   DateTime
  days      Float
  reason    String?
  justifUrl String?     // certificat médical, etc.
  decidedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  agent     Agent  @relation("LeaveRequester", fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  approver  Agent? @relation("LeaveApprover", fields: [approverId], references: [id])
  approverId String?

  approvals LeaveApproval[]

  @@index([status])
}

/// Trace d'une décision prise à un niveau de la chaîne de validation des
/// congés (Chef de Service, Doyen, DG/Recteur). Une ligne par décision.
model LeaveApproval {
  id        String             @id @default(cuid())
  level     LeaveApprovalLevel
  decision  LeaveDecision
  comment   String?
  decidedAt DateTime           @default(now())

  request   LeaveRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  requestId String
  decidedBy User?        @relation("LeaveApprovalDecider", fields: [decidedById], references: [id])
  decidedById String?

  @@index([requestId])
}

/// Solde de congés d'un agent par type et par année
model LeaveBalance {
  id         String    @id @default(cuid())
  year       Int
  type       LeaveType
  totalDays  Float
  usedDays   Float     @default(0)

  agent   Agent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId String

  @@unique([agentId, year, type])
}

// ============================================================
//  MODULE 5.5 — RECRUTEMENT & INTÉGRATION
// ============================================================

/// Offre d'emploi publiée
model JobPosting {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    StaffCategory
  status      JobStatus @default(OUVERT)
  openings    Int       @default(1)
  publishedAt DateTime  @default(now())
  closesAt    DateTime?

  service   Service? @relation(fields: [serviceId], references: [id])
  serviceId String?

  applications Application[]
}

/// Candidature à une offre — porte l'étape du pipeline
model Application {
  id            String           @id @default(cuid())
  candidateName String
  candidateEmail String
  candidatePhone String?
  cvUrl         String?          // lien externe (LinkedIn, drive…)
  cvFilename    String?          // nom du fichier uploadé ; chemin = ./uploads/cvs/{id}/{cvFilename}
  cvMimeType    String?          // ex: "application/pdf"
  cvSize        Int?             // octets
  stage         ApplicationStage @default(CANDIDATURE)
  interviewAt   DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  jobPostingId String

  applicationNotes ApplicationNote[]

  @@index([stage])
}

/// Note datée d'un évaluateur sur une candidature, à une étape donnée.
/// Permet de suivre l'historique des appréciations à chaque palier du pipeline.
model ApplicationNote {
  id            String           @id @default(cuid())
  body          String
  stage         ApplicationStage // étape au moment de la rédaction
  createdAt     DateTime         @default(now())

  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  applicationId String
  author        User?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId      String?

  @@index([applicationId, createdAt])
}

// ============================================================
//  MODULE 5.6 — FORMATION & DÉVELOPPEMENT
// ============================================================

/// Formation du catalogue (interne ou externe)
model TrainingCourse {
  id            String   @id @default(cuid())
  title         String
  category      String   // ex: "Pédagogie", "Numérique"
  description   String?
  isInternal    Boolean  @default(true)
  instructor    String?  // nom du formateur (ou intervenant)
  objectives    String?  // objectifs pédagogiques (texte libre)
  durationHours Int?     // durée totale en heures
  createdAt     DateTime @default(now())

  sessions TrainingSession[]
  modules  CourseModule[]
}

/// Module pédagogique d'un cours (sous-partie du programme)
model CourseModule {
  id            String  @id @default(cuid())
  title         String
  description   String?
  durationHours Int?
  order         Int     @default(0)

  course   TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  @@index([courseId, order])
}

/// Session planifiée d'une formation
model TrainingSession {
  id        String         @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  location  String?
  capacity  Int            @default(20)
  status    TrainingStatus @default(PLANIFIEE)

  course   TrainingCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId String

  enrollments TrainingEnrollment[]
}

/// Inscription d'un agent à une session de formation
model TrainingEnrollment {
  id        String           @id @default(cuid())
  status    EnrollmentStatus @default(INSCRIT)
  score     Float?
  createdAt DateTime         @default(now())

  agent     Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String

  @@unique([agentId, sessionId])
}

// ============================================================
//  MODULE 5.7 — ÉVALUATION & PERFORMANCE
// ============================================================

/// Campagne d'évaluation annuelle d'un agent
model Evaluation {
  id           String           @id @default(cuid())
  period       String           // ex: "2025"
  status       EvaluationStatus @default(PLANIFIEE)
  dueDate      DateTime?
  completedAt  DateTime?
  overallScore Float?           // note globale / 100
  objectives   String?
  comments     String?
  highPotential Boolean         @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  agent       Agent  @relation("Evaluee", fields: [agentId], references: [id], onDelete: Cascade)
  agentId     String
  evaluator   Agent? @relation("Evaluator", fields: [evaluatorId], references: [id])
  evaluatorId String?

  @@index([status])
}

// ============================================================
//  MODULE 5.8 — COMMUNICATION INTERNE
// ============================================================

/// Notification automatisée destinée à un utilisateur
model Notification {
  id        String           @id @default(cuid())
  type      NotificationType @default(INFO)
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, isRead])
}

/// Annonce de la direction
model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author      User   @relation(fields: [authorId], references: [id])
  authorId    String
  attachments AnnouncementAttachment[]
}

/// Pièce jointe d'une annonce (image ou fichier).
/// Chemin sur disque : `./uploads/announcements/{announcementId}/{filename}`
model AnnouncementAttachment {
  id        String   @id @default(cuid())
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String

  @@index([announcementId])
}

// ============================================================
//  MODULE 5.9 — CONFORMITÉ & ARCHIVES
// ============================================================

/// Document RH archivé (CNI, diplôme, casier, RIB, certificat médical, etc.)
/// Fichier stocké sur Supabase : documents/{id}/{fileName}. Les pièces
/// directement liées à un contrat (PDF signé, avenant, lettre de
/// notification) sont portées par leurs entités respectives.
model Document {
  id        String       @id @default(cuid())
  type      DocumentType
  title     String
  fileName  String
  mimeType  String
  size      Int
  createdAt DateTime     @default(now())

  agent      Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId    String?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  contractId String?

  uploadedBy   User?   @relation("DocumentUploader", fields: [uploadedById], references: [id])
  uploadedById String?

  @@index([type])
  @@index([agentId])
  @@index([contractId])
}

// ============================================================
//  BIEN-ÊTRE / ESPACE DE VIE
// ============================================================

enum WellbeingTopic {
  ENVIRONNEMENT   // avis sur l'environnement de travail
  AMELIORATION    // idée d'amélioration
  RECONNAISSANCE  // remerciement / félicitation
  AUTRE
}

enum WellbeingStatus {
  NOUVEAU
  LU
  TRAITE
}

/// Avis / idée déposé(e) par un employé — 100 % ANONYME : aucun lien vers
/// l'agent ou l'utilisateur n'est conservé. Vu et traité par la DRH.
model WellbeingPost {
  id        String          @id @default(cuid())
  topic     WellbeingTopic  @default(AUTRE)
  message   String
  status    WellbeingStatus @default(NOUVEAU)
  createdAt DateTime        @default(now())

  @@index([status])
  @@index([createdAt])
}
